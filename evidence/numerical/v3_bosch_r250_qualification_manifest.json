        "held_value": 0.0,
        "name": "mask_ion_rate",
        "owning_api": "tsv_process.bosch_etch(mask_ion_rate)",
        "required_followup": "run a separately frozen bounded mask-erosion/selectivity challenge before any mask-process-margin claim"
      },
      {
        "classification": "recipe_control_and_trajectory_index",
        "evidence_status": "known non-monotonic historical hypothesis",
        "exclusion_rationale": "varying cycle count independently here would break the required depth-matched morphology comparison",
