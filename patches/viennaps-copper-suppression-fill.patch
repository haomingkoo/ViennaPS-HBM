diff --git a/include/viennaps/models/psCopperSuppressionFill.hpp b/include/viennaps/models/psCopperSuppressionFill.hpp
new file mode 100644
index 0000000..97a8190
--- /dev/null
+++ b/include/viennaps/models/psCopperSuppressionFill.hpp
@@ -0,0 +1,292 @@
+#pragma once
+
+#include "../materials/psMaterialMap.hpp"
+#include "../process/psProcessModel.hpp"
+
+namespace viennaps {
+
+using namespace viennacore;
+
+/// Reduced quasi-steady suppressor-transport model for morphology-scale Cu TSV
+/// filling.
+///
+/// All rates are model coefficients until calibrated. This model retains the
+/// quasi-steady limit of the adsorption/deposition-deactivation structure with
+/// active/suppressed growth. It does not represent transient chemistry, Cu-ion
+/// concentration, electrolyte potential, or a fab current waveform and must
+/// not be described as an S-NDR result.
+struct CopperSuppressionFillParams {
+  double suppressorStickingProbability = 0.1;
+  double suppressorSourcePower = 1.;
+  double gasMeanFreePath = -1.;
+  double adsorptionStrength = 1.; // combined k_ads * suppressor activity
+  double deactivationRate = 1.;
+  double activeDepositionRate = 1.;
+  double suppressedDepositionRate = 0.01;
+  std::vector<Material> platingMaterials = {Material::Cu};
+
+  auto toProcessMetaData() const {
+    std::unordered_map<std::string, std::vector<double>> processData;
+    processData["suppressorStickingProbability"] = {
+        suppressorStickingProbability};
+    processData["suppressorSourcePower"] = {suppressorSourcePower};
+    processData["gasMeanFreePath"] = {gasMeanFreePath};
+    processData["adsorptionStrength"] = {adsorptionStrength};
+    processData["deactivationRate"] = {deactivationRate};
+    processData["activeDepositionRate"] = {activeDepositionRate};
+    processData["suppressedDepositionRate"] = {suppressedDepositionRate};
+    std::vector<double> materialIds;
+    materialIds.reserve(platingMaterials.size());
+    for (const auto material : platingMaterials)
+      materialIds.push_back(static_cast<double>(material.legacyId()));
+    processData["platingMaterials"] = std::move(materialIds);
+    return processData;
+  }
+};
+
+namespace impl {
+
+template <typename NumericType>
+class CopperSuppressionFillSurfaceModel : public SurfaceModel<NumericType> {
+  CopperSuppressionFillParams const &params_;
+  std::vector<Vec3D<NumericType>> lastCoordinates_;
+  std::vector<NumericType> lastMaterialIds_;
+  std::vector<NumericType> lastSuppressorFlux_;
+  std::vector<NumericType> lastCoverage_;
+  std::vector<NumericType> lastVelocity_;
+  std::vector<NumericType> lastAdsorptionTerm_;
+  std::vector<NumericType> lastDeactivationTerm_;
+  NumericType lastRelativeBalanceError_ = 0.;
+
+  NumericType velocity(NumericType theta, NumericType materialId) const {
+    const auto platingSurface = std::any_of(
+        params_.platingMaterials.begin(), params_.platingMaterials.end(),
+        [materialId](const auto material) {
+          return MaterialMap::isMaterial(materialId, material);
+        });
+    if (!platingSurface)
+      return 0.;
+    return params_.activeDepositionRate * (NumericType(1.) - theta) +
+           params_.suppressedDepositionRate * theta;
+  }
+
+  NumericType equilibriumCoverage(NumericType adsorption,
+                                  NumericType materialId) const {
+    if (adsorption <= 0.)
+      return 0.;
+    const auto activeVelocity = velocity(0., materialId);
+    const auto suppressedVelocity = velocity(1., materialId);
+    const auto deactivationActive =
+        params_.deactivationRate * activeVelocity;
+    const auto quadratic =
+        params_.deactivationRate * (activeVelocity - suppressedVelocity);
+    const auto scale = std::max(adsorption, deactivationActive);
+    if (scale <= 0.)
+      return 1.;
+    const auto normalizedLinear = adsorption / scale +
+                                  deactivationActive / scale;
+    const auto normalizedConstant = adsorption / scale;
+    const auto normalizedQuadratic = quadratic / scale;
+    if (normalizedQuadratic <=
+        std::numeric_limits<NumericType>::epsilon() * normalizedLinear)
+      return std::clamp(normalizedConstant / normalizedLinear,
+                        NumericType(0.), NumericType(1.));
+    const auto discriminant = std::max(
+        NumericType(0.), normalizedLinear * normalizedLinear -
+                            NumericType(4.) * normalizedQuadratic *
+                                normalizedConstant);
+    const auto denominator = normalizedLinear + std::sqrt(discriminant);
+    if (denominator <= 0.)
+      return 1.;
+    return std::clamp(NumericType(2.) * normalizedConstant / denominator,
+                      NumericType(0.), NumericType(1.));
+  }
+
+public:
+  explicit CopperSuppressionFillSurfaceModel(
+      CopperSuppressionFillParams const &params)
+      : params_(params) {}
+
+  SmartPointer<std::vector<NumericType>>
+  calculateVelocities(SmartPointer<PointData<NumericType>> fluxes,
+                      const std::vector<Vec3D<NumericType>> &coordinates,
+                      const std::vector<NumericType> &materialIds) override {
+    auto suppressorFlux = fluxes->getScalarData("SuppressorFlux");
+    assert(suppressorFlux && suppressorFlux->size() == materialIds.size());
+
+    auto rates = SmartPointer<std::vector<NumericType>>::New(
+        materialIds.size(), NumericType(0.));
+    std::vector<NumericType> coverage(materialIds.size(), 0.);
+    lastAdsorptionTerm_.assign(materialIds.size(), 0.);
+    lastDeactivationTerm_.assign(materialIds.size(), 0.);
+    lastRelativeBalanceError_ = 0.;
+    for (size_t i = 0; i < materialIds.size(); ++i) {
+      const auto adsorption = params_.adsorptionStrength *
+                              params_.suppressorStickingProbability *
+                              suppressorFlux->at(i);
+      if (!std::isfinite(adsorption))
+        throw std::runtime_error("non-finite suppressor adsorption term");
+      const auto theta = equilibriumCoverage(adsorption, materialIds[i]);
+      const auto localVelocity = velocity(theta, materialIds[i]);
+      const auto adsorptionTerm = adsorption * (NumericType(1.) - theta);
+      const auto deactivation =
+          params_.deactivationRate * localVelocity * theta;
+      const auto balanceScale = std::max(
+          {std::abs(adsorptionTerm), std::abs(deactivation),
+           std::numeric_limits<NumericType>::epsilon()});
+      coverage[i] = theta;
+      rates->at(i) = localVelocity;
+      lastAdsorptionTerm_[i] = adsorptionTerm;
+      lastDeactivationTerm_[i] = deactivation;
+      lastRelativeBalanceError_ = std::max(
+          lastRelativeBalanceError_,
+          std::abs(adsorptionTerm - deactivation) / balanceScale);
+    }
+
+    lastCoordinates_ = coordinates;
+    lastMaterialIds_ = materialIds;
+    lastSuppressorFlux_ = *suppressorFlux;
+    lastCoverage_ = std::move(coverage);
+    lastVelocity_ = *rates;
+    return rates;
+  }
+
+  const auto &getLastCoordinates() const { return lastCoordinates_; }
+  const auto &getLastMaterialIds() const { return lastMaterialIds_; }
+  const auto &getLastSuppressorFlux() const { return lastSuppressorFlux_; }
+  const auto &getLastCoverage() const { return lastCoverage_; }
+  const auto &getLastVelocity() const { return lastVelocity_; }
+  const auto &getLastAdsorptionTerm() const { return lastAdsorptionTerm_; }
+  const auto &getLastDeactivationTerm() const { return lastDeactivationTerm_; }
+  NumericType getLastRelativeBalanceError() const {
+    return lastRelativeBalanceError_;
+  }
+};
+
+template <typename NumericType, int D>
+class CopperSuppressorParticle
+    : public viennaray::Particle<CopperSuppressorParticle<NumericType, D>,
+                                 NumericType> {
+  const NumericType sticking_;
+  const NumericType sourcePower_;
+  const NumericType gasMeanFreePath_;
+
+public:
+  CopperSuppressorParticle(const NumericType sticking,
+                           const NumericType sourcePower,
+                           const NumericType gasMeanFreePath)
+      : sticking_(sticking), sourcePower_(sourcePower),
+        gasMeanFreePath_(gasMeanFreePath) {}
+
+  void surfaceCollision(NumericType rayWeight, const Vec3D<NumericType> &,
+                        const Vec3D<NumericType> &, const unsigned int primID,
+                        const int, PointData<NumericType> &localData,
+                        const PointData<NumericType> *, RNG &) override final {
+    localData.addToScalarData(0, primID, rayWeight);
+  }
+
+  std::pair<NumericType, Vec3D<NumericType>>
+  surfaceReflection(NumericType, const Vec3D<NumericType> &,
+                    const Vec3D<NumericType> &geomNormal,
+                    const unsigned int, const int,
+                    const PointData<NumericType> *,
+                    RNG &rng) override final {
+    const auto direction =
+        viennaray::ReflectionDiffuse<NumericType, D>(geomNormal, rng);
+    return {sticking_, direction};
+  }
+
+  NumericType getSourceDistributionPower() const override final {
+    return sourcePower_;
+  }
+  std::vector<std::string> getLocalDataLabels() const override final {
+    return {"SuppressorFlux"};
+  }
+  NumericType getMeanFreePath() const override final {
+    return gasMeanFreePath_;
+  }
+};
+
+} // namespace impl
+
+template <typename NumericType, int D>
+class CopperSuppressionFill : public ProcessModelCPU<NumericType, D> {
+  CopperSuppressionFillParams params_;
+  SmartPointer<impl::CopperSuppressionFillSurfaceModel<NumericType>>
+      surfaceModel_;
+
+public:
+  explicit CopperSuppressionFill(const CopperSuppressionFillParams &params)
+      : params_(params) {
+    if (params_.suppressorStickingProbability < 0. ||
+        params_.suppressorStickingProbability > 1.)
+      throw std::invalid_argument(
+          "suppressorStickingProbability must be in [0, 1]");
+    if (params_.suppressorSourcePower < 0.)
+      throw std::invalid_argument("suppressorSourcePower must be nonnegative");
+    const std::array<double, 7> finiteParameters = {
+        params_.suppressorStickingProbability,
+        params_.suppressorSourcePower,
+        params_.gasMeanFreePath,
+        params_.adsorptionStrength,
+        params_.deactivationRate,
+        params_.activeDepositionRate,
+        params_.suppressedDepositionRate};
+    if (!std::all_of(finiteParameters.begin(), finiteParameters.end(),
+                     [](double value) { return std::isfinite(value); }))
+      throw std::invalid_argument("all scalar parameters must be finite");
+    if (params_.adsorptionStrength < 0. || params_.deactivationRate < 0.)
+      throw std::invalid_argument(
+          "adsorptionStrength and deactivationRate must be nonnegative");
+    if (params_.suppressedDepositionRate < 0. ||
+        params_.activeDepositionRate < params_.suppressedDepositionRate)
+      throw std::invalid_argument(
+          "deposition rates require active >= suppressed >= 0");
+    if (params_.platingMaterials.empty())
+      throw std::invalid_argument("platingMaterials must not be empty");
+    if (!std::isfinite(params_.deactivationRate *
+                       params_.activeDepositionRate))
+      throw std::invalid_argument(
+          "deactivationRate * activeDepositionRate must be finite");
+    if (!std::isfinite(params_.adsorptionStrength *
+                       params_.suppressorStickingProbability))
+      throw std::invalid_argument(
+          "adsorptionStrength * stickingProbability must be finite");
+
+    auto particle =
+        std::make_unique<impl::CopperSuppressorParticle<NumericType, D>>(
+            params_.suppressorStickingProbability,
+            params_.suppressorSourcePower, params_.gasMeanFreePath);
+    surfaceModel_ = SmartPointer<
+        impl::CopperSuppressionFillSurfaceModel<NumericType>>::New(params_);
+    auto velocityField =
+        SmartPointer<DefaultVelocityField<NumericType, D>>::New();
+
+    this->setSurfaceModel(surfaceModel_);
+    this->setVelocityField(velocityField);
+    this->insertNextParticleType(particle);
+    this->setProcessName("CopperSuppressionFill");
+    this->processMetaData = params_.toProcessMetaData();
+  }
+
+  auto getLastCoordinates() const { return surfaceModel_->getLastCoordinates(); }
+  auto getLastMaterialIds() const { return surfaceModel_->getLastMaterialIds(); }
+  auto getLastSuppressorFlux() const {
+    return surfaceModel_->getLastSuppressorFlux();
+  }
+  auto getLastCoverage() const { return surfaceModel_->getLastCoverage(); }
+  auto getLastVelocity() const { return surfaceModel_->getLastVelocity(); }
+  auto getLastAdsorptionTerm() const {
+    return surfaceModel_->getLastAdsorptionTerm();
+  }
+  auto getLastDeactivationTerm() const {
+    return surfaceModel_->getLastDeactivationTerm();
+  }
+  NumericType getLastRelativeBalanceError() const {
+    return surfaceModel_->getLastRelativeBalanceError();
+  }
+};
+
+PS_PRECOMPILE_PRECISION_DIMENSION(CopperSuppressionFill)
