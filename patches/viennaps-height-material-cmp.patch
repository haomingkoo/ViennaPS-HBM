diff --git a/include/viennaps/models/psHeightMaterialCMP.hpp b/include/viennaps/models/psHeightMaterialCMP.hpp
new file mode 100644
index 0000000..c4f8a57
--- /dev/null
+++ b/include/viennaps/models/psHeightMaterialCMP.hpp
@@ -0,0 +1,166 @@
+#pragma once
+
+#include "../materials/psMaterialMap.hpp"
+#include "../process/psProcessModel.hpp"
+#include "../process/psSurfaceModel.hpp"
+#include "../process/psVelocityField.hpp"
+
+namespace viennaps {
+
+using namespace viennacore;
+
+/// Parameters for an uncalibrated height/material CMP abstraction.
+///
+/// This model does not calculate pad contact pressure, pad deformation,
+/// slurry transport, or endpoint-sensor response. Rates are dimensionless
+/// morphology coefficients until calibrated.
+struct HeightMaterialCMPParams {
+  double stopHeight = 0.;
+  double complianceLength = 0.1;
+  double residualContact = 0.05;
+  double platedCuRemovalRate = 1.;
+  Material cuSeedMaterial = Material::Undefined;
+  double cuSeedRemovalRate = 1.;
+  double tantalumNitrideRemovalRate = 0.25;
+  double siliconDioxideRemovalRate = 0.01;
+  double siliconRemovalRate = 0.01;
+
+  auto toProcessMetaData() const {
+    std::unordered_map<std::string, std::vector<double>> processData;
+    processData["stopHeight"] = {stopHeight};
+    processData["complianceLength"] = {complianceLength};
+    processData["residualContact"] = {residualContact};
+    processData["platedCuRemovalRate"] = {platedCuRemovalRate};
+    processData["cuSeedMaterial"] = {
+        static_cast<double>(cuSeedMaterial.legacyId())};
+    processData["cuSeedRemovalRate"] = {cuSeedRemovalRate};
+    processData["tantalumNitrideRemovalRate"] = {
+        tantalumNitrideRemovalRate};
+    processData["siliconDioxideRemovalRate"] = {siliconDioxideRemovalRate};
+    processData["siliconRemovalRate"] = {siliconRemovalRate};
+    processData["UncalibratedHeightMaterialAbstraction"] = {1.};
+    processData["PadPressurePhysicsRepresented"] = {0.};
+    processData["RayTracingUsed"] = {0.};
+    return processData;
+  }
+};
+
+namespace impl {
+
+template <typename NumericType>
+NumericType heightMaterialCMPWeight(const NumericType height,
+                                    const HeightMaterialCMPParams &params) {
+  const auto fraction = std::clamp(
+      (height - static_cast<NumericType>(params.stopHeight)) /
+          static_cast<NumericType>(params.complianceLength),
+      NumericType(0.), NumericType(1.));
+  const auto smooth =
+      fraction * fraction * (NumericType(3.) - NumericType(2.) * fraction);
+  return static_cast<NumericType>(params.residualContact) +
+         (NumericType(1.) -
+          static_cast<NumericType>(params.residualContact)) *
+             smooth;
+}
+
+template <typename NumericType>
+NumericType heightMaterialCMPRate(const int material,
+                                  const HeightMaterialCMPParams &params) {
+  if (MaterialMap::isMaterial(material, params.cuSeedMaterial))
+    return static_cast<NumericType>(params.cuSeedRemovalRate);
+  if (MaterialMap::isMaterial(material, Material::Cu))
+    return static_cast<NumericType>(params.platedCuRemovalRate);
+  if (MaterialMap::isMaterial(material, Material::TaN))
+    return static_cast<NumericType>(params.tantalumNitrideRemovalRate);
+  if (MaterialMap::isMaterial(material, Material::SiO2))
+    return static_cast<NumericType>(params.siliconDioxideRemovalRate);
+  if (MaterialMap::isMaterial(material, Material::Si))
+    return static_cast<NumericType>(params.siliconRemovalRate);
+  return NumericType(0.);
+}
+
+template <typename NumericType, int D>
+class HeightMaterialCMPVelocityField : public VelocityField<NumericType, D> {
+  const HeightMaterialCMPParams &params_;
+
+public:
+  explicit HeightMaterialCMPVelocityField(
+      const HeightMaterialCMPParams &params)
+      : params_(params) {}
+
+  NumericType getScalarVelocity(const Vec3D<NumericType> &coordinate,
+                                int material,
+                                const Vec3D<NumericType> &,
+                                unsigned long) override {
+    const auto rate = heightMaterialCMPRate<NumericType>(material, params_);
+    const auto weight =
+        heightMaterialCMPWeight<NumericType>(coordinate[D - 1], params_);
+    return -rate * weight;
+  }
+};
+
+} // namespace impl
+
+template <typename NumericType, int D>
+class HeightMaterialCMP : public ProcessModelCPU<NumericType, D> {
+  HeightMaterialCMPParams params_;
+
+  void validate() const {
+    const std::array<double, 8> scalars = {
+        params_.stopHeight,
+        params_.complianceLength,
+        params_.residualContact,
+        params_.platedCuRemovalRate,
+        params_.cuSeedRemovalRate,
+        params_.tantalumNitrideRemovalRate,
+        params_.siliconDioxideRemovalRate,
+        params_.siliconRemovalRate};
+    if (!std::all_of(scalars.begin(), scalars.end(),
+                     [](double value) { return std::isfinite(value); }))
+      throw std::invalid_argument("all HeightMaterialCMP scalars must be finite");
+    if (params_.complianceLength <= 0.)
+      throw std::invalid_argument("complianceLength must be positive");
+    if (params_.residualContact < 0. || params_.residualContact > 1.)
+      throw std::invalid_argument("residualContact must be in [0, 1]");
+    const std::array<double, 5> rates = {
+        params_.platedCuRemovalRate,
+        params_.cuSeedRemovalRate,
+        params_.tantalumNitrideRemovalRate,
+        params_.siliconDioxideRemovalRate,
+        params_.siliconRemovalRate};
+    if (!std::all_of(rates.begin(), rates.end(),
+                     [](double value) { return value >= 0.; }))
+      throw std::invalid_argument("material removal rates must be nonnegative");
+    if (params_.cuSeedMaterial == Material::Undefined)
+      throw std::invalid_argument("cuSeedMaterial must be explicitly assigned");
+    if (params_.cuSeedMaterial == Material::Cu)
+      throw std::invalid_argument(
+          "cuSeedMaterial must remain distinct from plated Cu");
+  }
+
+public:
+  explicit HeightMaterialCMP(const HeightMaterialCMPParams &params)
+      : params_(params) {
+    validate();
+    auto surfaceModel = SmartPointer<SurfaceModel<NumericType>>::New();
+    auto velocityField = SmartPointer<
+        impl::HeightMaterialCMPVelocityField<NumericType, D>>::New(params_);
+    this->setSurfaceModel(surfaceModel);
+    this->setVelocityField(velocityField);
+    this->setProcessName("HeightMaterialCMP");
+    this->processMetaData = params_.toProcessMetaData();
+  }
+
+  NumericType evaluateContactWeight(NumericType height) const {
+    return impl::heightMaterialCMPWeight<NumericType>(height, params_);
+  }
+
+  NumericType evaluateVelocity(NumericType height, Material material) const {
+    return -impl::heightMaterialCMPRate<NumericType>(material.legacyId(),
+                                                     params_) *
+           evaluateContactWeight(height);
+  }
+};
+
+PS_PRECOMPILE_PRECISION_DIMENSION(HeightMaterialCMP)
+
+} // namespace viennaps
