{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bosch tutorial evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "title", "scope", "equipment_mapping", "measurement_implementation", "factors", "targets", "interactions", "interior_study", "interior_cases", "focused_study", "focused_cases", "default_interaction", "default_interior_case", "measurement_example_case_id", "traveler_etch_case_id", "review"],
  "properties": {
    "schema_version": {"const": 4},
    "title": {"type": "string", "minLength": 1},
    "scope": {"type": "string", "minLength": 1},
    "equipment_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relationship", "chain"],
      "properties": {
        "relationship": {"const": "many-to-many and uncalibrated"},
        "chain": {"type": "array", "minItems": 5, "items": {"type": "string", "minLength": 1}}
      }
    },
    "measurement_implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "symbol"],
      "properties": {
        "path": {"const": "profile_shape_metrics.py"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "symbol": {"const": "measure_target_via_profile_2d"}
      }
    },
    "factors": {
      "type": "object",
      "minProperties": 6,
      "additionalProperties": {"$ref": "#/$defs/factor"}
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basis", "depth", "depth_tolerance", "target_cd", "maximum_cd_error", "maximum_bow"],
      "properties": {
        "basis": {
          "type": "object",
          "additionalProperties": false,
          "required": ["classification", "physical_qualification", "source"],
          "properties": {
            "classification": {"const": "assumed_study_target"},
            "physical_qualification": {"const": false},
            "source": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "sha256", "section"],
              "properties": {
                "path": {"const": "program.md"},
                "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                "section": {"const": "Assumed study comparison bands"}
              }
            }
          }
        },
        "depth": {"type": "number"},
        "depth_tolerance": {"type": "number", "exclusiveMinimum": 0},
        "target_cd": {"type": "number", "exclusiveMinimum": 0},
        "maximum_cd_error": {"type": "number", "minimum": 0},
        "maximum_bow": {"type": "number", "minimum": 0}
      }
    },
    "interactions": {"type": "array", "minItems": 28, "maxItems": 28, "items": {"$ref": "#/$defs/case"}},
    "interior_study": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "case_count", "factor_order", "coordinate_levels", "descriptive_main_effects", "interpretation"],
      "properties": {
        "method": {"type": "string", "minLength": 1},
        "case_count": {"const": 18},
        "factor_order": {"type": "array", "minItems": 6, "maxItems": 6, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "coordinate_levels": {"type": "array", "minItems": 3, "items": {"type": "number"}},
        "descriptive_main_effects": {
          "type": "object",
          "additionalProperties": false,
          "required": ["depth", "maximum_cd_error", "bow", "floor_flatness_pv"],
          "properties": {
            "depth": {"$ref": "#/$defs/main_effect_ranking"},
            "maximum_cd_error": {"$ref": "#/$defs/main_effect_ranking"},
            "bow": {"$ref": "#/$defs/main_effect_ranking"},
            "floor_flatness_pv": {"$ref": "#/$defs/main_effect_ranking"}
          }
        },
        "interpretation": {"type": "string", "minLength": 1}
      }
    },
    "interior_cases": {"type": "array", "minItems": 3, "items": {"$ref": "#/$defs/case"}},
    "focused_study": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_count", "unique_cells", "factor_order", "repeated_cell", "interpretation"],
      "properties": {
        "case_count": {"const": 12},
        "unique_cells": {"const": 9},
        "factor_order": {"const": ["ion_source_exponent", "ion_rate"]},
        "repeated_cell": {"const": "e141_i0.06324555"},
        "interpretation": {"type": "string", "minLength": 1}
      }
    },
    "focused_cases": {"type": "array", "minItems": 12, "maxItems": 12, "items": {"$ref": "#/$defs/case"}},
    "default_interaction": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "string"}},
    "default_interior_case": {"type": "string", "minLength": 16},
    "measurement_example_case_id": {"type": "string", "minLength": 16},
    "traveler_etch_case_id": {"type": "string", "minLength": 16},
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid_cases", "hard_gate_passes", "decision", "derivation"],
      "properties": {
        "valid_cases": {"const": 28},
        "hard_gate_passes": {"type": "integer", "minimum": 0, "maximum": 28},
        "decision": {"type": "string", "minLength": 1},
        "derivation": {"type": "string", "minLength": 1}
      }
    }
  },
  "$defs": {
    "main_effect_ranking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available_cases", "ranking"],
      "properties": {
        "available_cases": {"type": "integer", "minimum": 1, "maximum": 18},
        "ranking": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["factor", "coefficient"],
            "properties": {
              "factor": {"type": "string", "minLength": 1},
              "coefficient": {"type": "number"}
            }
          }
        }
      }
    },
    "factor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "kind", "equipment_influences", "meaning", "direction", "calibration_status", "calibration_note"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "kind": {"enum": ["model control", "model coefficient"]},
        "equipment_influences": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "meaning": {"type": "string", "minLength": 1},
        "direction": {"type": "string", "minLength": 1},
        "calibration_status": {"enum": ["Recipe-linked", "Fit from data"]},
        "calibration_note": {"type": "string", "minLength": 1}
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["depth", "cd_top", "cd_middle", "cd_bottom", "maximum_cd_error", "bow", "scallop_rms", "sidewall_angle_deg", "profile_shape_rmse", "profile_max_deviation", "profile_symmetry_rms", "profile_wall_rmse", "profile_floor_rmse", "floor_flatness_pv", "floor_center_relief", "floor_resolution_status", "profile_measurement_status", "selected_cycle", "hard_gate_pass", "trajectory_class", "measurement_method", "numerically_qualified", "maximum_cd_error_fraction", "maximum_cd_error_cd", "maximum_bow_fraction", "maximum_bow_actual_radius", "maximum_bow_reference_radius"],
      "properties": {
        "depth": {"type": "number"},
        "cd_top": {"type": "number"},
        "cd_middle": {"type": "number"},
        "cd_bottom": {"type": "number"},
        "maximum_cd_error": {"type": "number", "minimum": 0},
        "bow": {"type": "number", "minimum": 0},
        "scallop_rms": {"type": "number", "minimum": 0},
        "sidewall_angle_deg": {"type": "number"},
        "profile_shape_rmse": {"type": ["number", "null"], "minimum": 0},
        "profile_max_deviation": {"type": ["number", "null"], "minimum": 0},
        "profile_symmetry_rms": {"type": ["number", "null"], "minimum": 0},
        "profile_wall_rmse": {"type": "number", "minimum": 0},
        "profile_floor_rmse": {"type": ["number", "null"], "minimum": 0},
        "floor_flatness_pv": {"type": ["number", "null"], "minimum": 0},
        "floor_center_relief": {"type": ["number", "null"]},
        "floor_resolution_status": {"enum": ["flat_within_resolution", "resolved_nonflatness", "unavailable"]},
        "profile_measurement_status": {"enum": ["complete", "partial"]},
        "selected_cycle": {"type": "integer", "minimum": 0},
        "hard_gate_pass": {"type": "boolean"},
        "trajectory_class": {"type": "string", "minLength": 1},
        "measurement_method": {"const": "full_width_two_wall_remeasurement"},
        "numerically_qualified": {"const": false},
        "maximum_cd_error_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "maximum_cd_error_cd": {"type": "number", "minimum": 0},
        "maximum_bow_fraction": {"type": "number", "minimum": 0, "maximum": 1},
        "maximum_bow_actual_radius": {"type": "number", "minimum": 0},
        "maximum_bow_reference_radius": {"type": "number", "minimum": 0}
      }
    },
    "material": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "surface_path"],
      "properties": {
        "id": {"const": "silicon"},
        "surface_path": {"type": "string", "minLength": 1, "pattern": "^M"}
      }
    },
    "citation": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "line_number": {"type": "integer", "minimum": 1},
        "selector": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "case": {
      "type": "object",
      "required": ["case_id", "recipe", "metrics", "materials", "elapsed_s", "rays_per_point", "checkpoint_sha256", "citation"],
      "properties": {
        "case_id": {"type": "string", "pattern": "^[0-9a-f]{16}$"},
        "interaction": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "string"}},
        "levels": {"type": "object", "minProperties": 2, "additionalProperties": {"enum": ["low", "high"]}},
        "values": {"type": "object", "minProperties": 2, "additionalProperties": {"type": "number"}},
        "normalized_coordinates": {"type": "object", "additionalProperties": {"type": "number"}},
        "recipe": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "number"}},
        "metrics": {"$ref": "#/$defs/metrics"},
        "materials": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/material"}},
        "elapsed_s": {"type": "number", "minimum": 0},
        "rays_per_point": {"const": 500},
        "checkpoint_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "citation": {"$ref": "#/$defs/citation"}
      },
      "additionalProperties": false
    }
  }
}
