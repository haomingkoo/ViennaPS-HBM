{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scope", "sources", "cases", "checks", "claim", "does_not_prove"],
  "properties": {
    "schema_version": {"const": 1},
    "scope": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "step", "metrics"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "step": {"enum": ["mask", "bosch_etch"]},
          "metrics": {
            "type": "object",
            "minProperties": 5,
            "additionalProperties": {"type": "number"}
          }
        }
      }
    },
    "checks": {
      "type": "object",
      "minProperties": 6,
      "additionalProperties": {"const": true}
    },
    "claim": {"type": "string", "minLength": 1},
    "does_not_prove": {"type": "string", "minLength": 1}
  }
}
