{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kooexperience.com/ViennaPS-HBM/schemas/pattern-bosch-range-pilot.schema.json",
  "title": "Coarse mask and Bosch range-pilot design",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "campaign", "authority", "status", "purpose", "method",
    "inference_policy", "sources", "endpoint", "numerics", "execution",
    "rng_policy", "comparison_context", "geometry",
    "held_controls", "required_measurements", "invalidity_rule", "factors",
    "diagnostics", "cases", "output"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "campaign": {"const": "pattern-bosch-range-pilot-v1"},
    "authority": {"const": "coarse_model_range_pilot_only"},
    "status": {"const": "frozen_design"},
    "purpose": {"type": "string", "minLength": 1},
    "method": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "construction", "interpretation"],
      "properties": {
        "name": {"const": "25-case three-level range pilot (DSD matrix)"},
        "construction": {"type": "string", "minLength": 1},
        "interpretation": {"type": "string", "minLength": 1}
      }
    },
    "inference_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "prohibited"],
      "properties": {
        "allowed": {"type": "array", "minItems": 5, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "prohibited": {"type": "array", "minItems": 5, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "sources": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "depth_matched_selection", "reason"],
      "properties": {
        "mode": {"const": "final_completed_cycle"},
        "depth_matched_selection": {"const": false},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "numerics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grid_delta", "rays_per_point", "threads_per_worker", "simulation_dimension", "status"],
      "properties": {
        "grid_delta": {"type": "number", "exclusiveMinimum": 0},
        "rays_per_point": {"type": "integer", "minimum": 1},
        "threads_per_worker": {"type": "integer", "minimum": 1},
        "simulation_dimension": {"const": 2},
        "status": {"const": "coarse_pilot_not_numerically_qualified"}
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_cap", "executor", "maximum_workers", "retry_policy", "checkpoint_policy", "early_stop_policy"],
      "properties": {
        "case_cap": {"const": 25},
        "executor": {"const": "sequential_resumable"},
        "maximum_workers": {"const": 1},
        "retry_policy": {"type": "string", "minLength": 1},
        "checkpoint_policy": {"type": "string", "minLength": 1},
        "early_stop_policy": {"type": "string", "minLength": 1}
      }
    },
    "rng_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shared_base_seed_label_across_rows", "pointwise_common_random_numbers_not_claimed", "independent_repeats_present"],
      "properties": {
        "shared_base_seed_label_across_rows": {"const": true},
        "pointwise_common_random_numbers_not_claimed": {"const": true},
        "independent_repeats_present": {"const": false}
      }
    },
    "comparison_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_class", "opening_cd", "mask_height", "etch_depth", "depth_tolerance", "max_width_error", "max_wall_bulge", "interpretation"],
      "properties": {
        "evidence_class": {"const": "assumed_study_band"},
        "opening_cd": {"type": "number", "exclusiveMinimum": 0},
        "mask_height": {"type": "number", "exclusiveMinimum": 0},
        "etch_depth": {"type": "number", "exclusiveMinimum": 0},
        "depth_tolerance": {"type": "number", "exclusiveMinimum": 0},
        "max_width_error": {"type": "number", "minimum": 0},
        "max_wall_bulge": {"type": "number", "minimum": 0},
        "interpretation": {"type": "string", "minLength": 1}
      }
    },
    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hole_shape", "mask_height", "x_extent", "y_extent"],
      "properties": {
        "hole_shape": {"const": "FULL"},
        "mask_height": {"type": "number", "exclusiveMinimum": 0},
        "x_extent": {"type": "number", "exclusiveMinimum": 0},
        "y_extent": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "held_controls": {"type": "object", "minProperties": 1},
    "required_measurements": {
      "type": "array",
      "minItems": 14,
      "maxItems": 14,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}
    },
    "invalidity_rule": {"type": "string", "minLength": 1},
    "factors": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "registry_id", "levels", "range_status", "range_source"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "registry_id": {"type": "string", "pattern": "^[A-Za-z0-9_]+$"},
          "levels": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {"type": "number"}
          },
          "range_status": {"const": "candidate_model_space_bracket"},
          "range_source": {"const": "docs/range-research.md#candidate-bracket-for-the-first-bosch-range-study"}
        }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_count", "linear_model_rank", "maximum_absolute_linear_correlation", "maximum_absolute_main_to_quadratic_cross_product", "maximum_absolute_main_to_interaction_cross_product"],
      "properties": {
        "run_count": {"const": 25},
        "linear_model_rank": {"const": 13},
        "maximum_absolute_linear_correlation": {"const": 0},
        "maximum_absolute_main_to_quadratic_cross_product": {"const": 0},
        "maximum_absolute_main_to_interaction_cross_product": {"const": 0}
      }
    },
    "cases": {
      "type": "array",
      "minItems": 25,
      "maxItems": 25,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["campaign", "design_row", "coded_levels", "recipe", "derived_exposures", "rng_seed", "numerics", "case_id"],
        "properties": {
          "campaign": {"const": "pattern-bosch-range-pilot-v1"},
          "design_row": {"type": "integer", "minimum": 0, "maximum": 24},
          "coded_levels": {
            "type": "array",
            "minItems": 12,
            "maxItems": 12,
            "items": {"enum": [-1, 0, 1]}
          },
          "recipe": {"type": "object", "minProperties": 12},
          "derived_exposures": {
            "type": "object",
            "additionalProperties": false,
            "required": ["total_cycle_etch_duration", "total_etch_duration_including_open", "total_polymer_deposition_amount", "total_polymer_directional_removal_amount"],
            "properties": {
              "total_cycle_etch_duration": {"type": "number", "minimum": 0},
              "total_etch_duration_including_open": {"type": "number", "minimum": 0},
              "total_polymer_deposition_amount": {"type": "number", "minimum": 0},
              "total_polymer_directional_removal_amount": {"type": "number", "maximum": 0}
            }
          },
          "rng_seed": {"type": "integer", "minimum": 0},
          "numerics": {
            "type": "object",
            "additionalProperties": false,
            "required": ["grid_delta", "rays_per_point"],
            "properties": {
              "grid_delta": {"type": "number", "exclusiveMinimum": 0},
              "rays_per_point": {"type": "integer", "minimum": 1}
            }
          },
          "case_id": {"type": "string", "pattern": "^[0-9a-f]{16}$"}
        }
      }
    },
    "output": {"type": "string", "minLength": 1}
  }
}
