{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kooexperience.com/ViennaPS-HBM/schemas/ray-benefit-review.schema.json",
  "title": "Observed Bosch ray-count cost and variation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "title", "status", "question", "interpretation_rules", "datasets", "excluded_studies", "highest_supported_claim", "next_evidence", "provenance", "sources"],
  "properties": {
    "schema_version": {"const": 1},
    "title": {"type": "string", "minLength": 1},
    "status": {"const": "reviewed_selected_saved_evidence"},
    "question": {"type": "string", "minLength": 1},
    "interpretation_rules": {"type": "array", "minItems": 4, "items": {"type": "string", "minLength": 1}},
    "datasets": {
      "type": "array",
      "prefixItems": [
        {"$ref": "#/$defs/ladder"},
        {"$ref": "#/$defs/pairedPanel"},
        {"$ref": "#/$defs/factorCheck"}
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "highest_supported_claim": {"type": "string", "minLength": 1},
    "next_evidence": {"type": "string", "minLength": 1},
    "excluded_studies": {"type": "array", "minItems": 4, "items": {"type": "string", "minLength": 1}},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["builder", "schema"],
      "properties": {"builder": {"$ref": "#/$defs/citation"}, "schema": {"$ref": "#/$defs/citation"}}
    },
    "sources": {"type": "array", "minItems": 3, "items": {"$ref": "#/$defs/citation"}}
  },
  "$defs": {
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "selector", "line_numbers"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "selector": {"type": "string", "minLength": 1},
        "line_numbers": {"type": ["array", "null"], "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 1}}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count", "minimum", "median", "maximum", "p10", "p90", "sample_sd"],
      "properties": {
        "count": {"type": "integer", "minimum": 2},
        "minimum": {"type": "number"},
        "median": {"type": "number"},
        "maximum": {"type": "number"},
        "p10": {"type": "number"},
        "p90": {"type": "number"},
        "sample_sd": {"type": "number", "minimum": 0}
      }
    },
    "metricSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["depth", "cd_top", "cd_middle", "cd_bottom", "max_bow"],
      "properties": {
        "depth": {"$ref": "#/$defs/summary"},
        "cd_top": {"$ref": "#/$defs/summary"},
        "cd_middle": {"$ref": "#/$defs/summary"},
        "cd_bottom": {"$ref": "#/$defs/summary"},
        "max_bow": {"$ref": "#/$defs/summary"}
      }
    },
    "level": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rays_per_point", "run_count", "latency_s", "between_seed_spread", "change_from_previous_level"],
      "properties": {
        "rays_per_point": {"enum": [250, 1000, 2000, 4000]},
        "run_count": {"const": 8},
        "latency_s": {"$ref": "#/$defs/summary"},
        "between_seed_spread": {"$ref": "#/$defs/metricSet"},
        "change_from_previous_level": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
                "required": ["from_rays", "to_rays", "paired_absolute_change", "ratio_of_median_latencies"],
              "properties": {
                "from_rays": {"type": "integer", "minimum": 1},
                "to_rays": {"type": "integer", "minimum": 1},
                "paired_absolute_change": {"$ref": "#/$defs/metricSet"},
                "ratio_of_median_latencies": {"type": "number", "exclusiveMinimum": 0}
              }
            }
          ]
        }
      }
    },
    "ladder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scope", "comparison_type", "levels", "limits", "citations"],
      "properties": {
        "id": {"const": "same_recipe_ray_ladder"},
        "scope": {"type": "string", "minLength": 1},
        "comparison_type": {"type": "string", "minLength": 1},
        "levels": {
          "type": "array",
          "prefixItems": [
            {"allOf": [{"$ref": "#/$defs/level"}, {"properties": {"rays_per_point": {"const": 250}, "change_from_previous_level": {"type": "null"}}}]},
            {"allOf": [{"$ref": "#/$defs/level"}, {"properties": {"rays_per_point": {"const": 1000}, "change_from_previous_level": {"properties": {"from_rays": {"const": 250}, "to_rays": {"const": 1000}}}}}]},
            {"allOf": [{"$ref": "#/$defs/level"}, {"properties": {"rays_per_point": {"const": 2000}, "change_from_previous_level": {"properties": {"from_rays": {"const": 1000}, "to_rays": {"const": 2000}}}}}]},
            {"allOf": [{"$ref": "#/$defs/level"}, {"properties": {"rays_per_point": {"const": 4000}, "change_from_previous_level": {"properties": {"from_rays": {"const": 2000}, "to_rays": {"const": 4000}}}}}]}
          ],
          "items": false,
          "minItems": 4,
          "maxItems": 4
        },
        "limits": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "citations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/citation"}}
      }
    },
    "pairedPanel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scope", "comparison_type", "pair_count", "latency_s", "paired_absolute_change", "complete_measurement_pairs", "selected_cycle_match_count", "limits", "citations"],
      "properties": {
        "id": {"const": "diverse_500_to_2000_pairs"},
        "scope": {"type": "string", "minLength": 1},
        "comparison_type": {"type": "string", "minLength": 1},
        "pair_count": {"const": 13},
        "latency_s": {"type": "object", "additionalProperties": false, "required": ["500", "2000"], "properties": {"500": {"$ref": "#/$defs/summary"}, "2000": {"$ref": "#/$defs/summary"}}},
        "paired_absolute_change": {"type": "object", "additionalProperties": false, "required": ["depth", "largest_sampled_cd", "max_bow"], "properties": {"depth": {"$ref": "#/$defs/summary"}, "largest_sampled_cd": {"$ref": "#/$defs/summary"}, "max_bow": {"$ref": "#/$defs/summary"}}},
        "complete_measurement_pairs": {"const": 13},
        "selected_cycle_match_count": {"const": 13},
        "limits": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "citations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/citation"}}
      }
    },
    "factorCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scope", "candidate_rays", "comparison_rays", "factor_ranking_spearman", "broad_outcome_matches", "trajectory_matches", "anchor_count", "median_descriptive_speedup", "limit", "citations"],
      "properties": {
        "id": {"const": "commissioning_factor_direction_check"},
        "scope": {"type": "string", "minLength": 1},
        "candidate_rays": {"const": 500},
        "comparison_rays": {"const": 2000},
        "factor_ranking_spearman": {"type": "number", "minimum": -1, "maximum": 1},
        "broad_outcome_matches": {"type": "integer", "minimum": 0, "maximum": 13},
        "trajectory_matches": {"type": "integer", "minimum": 0, "maximum": 13},
        "anchor_count": {"const": 13},
        "median_descriptive_speedup": {"type": "number", "exclusiveMinimum": 0},
        "limit": {"type": "string", "minLength": 1},
        "citations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/citation"}}
      }
    }
  }
}
