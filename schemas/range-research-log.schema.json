{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "access_date", "records"],
  "properties": {
    "schema_version": {"const": 1},
    "access_date": {"type": "string", "format": "date"},
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["timestamp", "query", "status", "source", "location", "tool_or_chemistry", "geometry", "applicability", "interpretation", "next_action"],
        "properties": {
          "timestamp": {"type": "string", "format": "date-time"},
          "query": {"type": "string", "minLength": 1},
          "status": {"enum": ["usable_api_evidence", "example_not_range", "usable_mechanism_no_transferable_range", "no_usable_evidence", "search_failed", "needs_investigation"]},
          "source": {"type": ["string", "null"], "format": "uri"},
          "location": {"type": ["string", "null"]},
          "tool_or_chemistry": {"type": "string", "minLength": 1},
          "geometry": {"type": ["string", "null"]},
          "applicability": {"type": "string", "minLength": 1},
          "interpretation": {"type": "string", "minLength": 1},
          "next_action": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
