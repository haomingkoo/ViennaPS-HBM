{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kooexperience.com/ViennaPS-HBM/schemas/pattern-bosch-measurement-contract.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scope", "launch_status", "sources", "metrics", "qualification_rule"],
  "properties": {
    "schema_version": {"const": 2},
    "scope": {"type": "string", "minLength": 1},
    "launch_status": {
      "enum": ["blocked_pending_measurement_qualification", "qualified_for_screening"]
    },
    "sources": {
      "type": "array",
      "minItems": 6,
      "items": {"$ref": "#/$defs/fileSource"}
    },
    "metrics": {
      "type": "array",
      "minItems": 14,
      "maxItems": 14,
      "items": {"$ref": "#/$defs/metric"}
    },
    "qualification_rule": {"type": "string", "minLength": 1}
  },
  "allOf": [
    {
      "if": {
        "properties": {"launch_status": {"const": "qualified_for_screening"}},
        "required": ["launch_status"]
      },
      "then": {
        "properties": {
          "metrics": {
            "items": {
              "allOf": [
                {"$ref": "#/$defs/metric"},
                {
                  "properties": {
                    "qualification_status": {"const": "qualified"},
                    "analytic_reference_evidence": {"type": "object"},
                    "feature_present_evidence": {"type": "object"},
                    "missingness_evidence": {"type": "object"},
                    "resolution_bracket": {"type": "object"},
                    "numerical_envelope": {"type": "object"},
                    "repeat_envelope": {"type": "object"},
                    "useful_change_threshold": {"type": "object"},
                    "useful_change_evidence_class": {
                      "enum": ["geometry_derived", "literature_derived", "assumed_model_study"]
                    }
                  }
                }
              ]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "fileSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "nullableEvidence": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["path", "sha256", "selector"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "selector": {"type": "string", "pattern": "^/"}
      }
    },
    "nullableMeasuredEvidence": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["value", "units", "method", "scope", "source"],
      "properties": {
        "value": {"type": "number", "minimum": 0},
        "units": {"type": "string", "minLength": 1},
        "method": {"type": "string", "minLength": 1},
        "scope": {"type": "string", "minLength": 1},
        "source": {"$ref": "#/$defs/fileSource"}
      }
    },
    "nullableBracket": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["resolved_at_or_above", "unresolved_at_or_below", "units", "scope", "source"],
      "properties": {
        "resolved_at_or_above": {"type": "number", "minimum": 0},
        "unresolved_at_or_below": {"type": "number", "minimum": 0},
        "units": {"type": "string", "minLength": 1},
        "scope": {"type": "string", "minLength": 1},
        "source": {"$ref": "#/$defs/fileSource"}
      }
    },
    "nullableParity": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["maximum_absolute_difference", "path", "sha256", "line_numbers"],
      "properties": {
        "maximum_absolute_difference": {"type": "number", "minimum": 0},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "line_numbers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "integer", "minimum": 1}
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "step", "extractor", "definition", "definition_sha256", "region", "units",
        "required_for", "missing_value_rule", "representation_domain",
        "analytic_reference_evidence", "feature_present_evidence", "missingness_evidence",
        "resolution_bracket", "save_reload_parity", "numerical_envelope", "repeat_envelope",
        "useful_change_threshold", "useful_change_evidence_class", "qualification_status"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "step": {"enum": ["mask", "bosch_etch"]},
        "extractor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "symbol", "output_key", "sha256"],
          "properties": {
            "path": {"const": "traveler_metrics.py"},
            "symbol": {"enum": ["pattern_metrics_2d", "measure_full_via_profile_2d"]},
            "output_key": {"type": "string", "minLength": 1},
            "sha256": {"$ref": "#/$defs/sha256"}
          }
        },
        "definition": {"type": "string", "minLength": 1},
        "definition_sha256": {"$ref": "#/$defs/sha256"},
        "region": {"type": "string", "minLength": 1},
        "units": {"type": "string", "minLength": 1},
        "required_for": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["range_finding", "screening", "confirmation"]}
        },
        "missing_value_rule": {"const": "block the affected decision; never replace with zero"},
        "representation_domain": {"type": "string", "minLength": 1},
        "analytic_reference_evidence": {"$ref": "#/$defs/nullableEvidence"},
        "feature_present_evidence": {"$ref": "#/$defs/nullableEvidence"},
        "missingness_evidence": {"$ref": "#/$defs/nullableEvidence"},
        "resolution_bracket": {"$ref": "#/$defs/nullableBracket"},
        "save_reload_parity": {"$ref": "#/$defs/nullableParity"},
        "numerical_envelope": {"$ref": "#/$defs/nullableMeasuredEvidence"},
        "repeat_envelope": {"$ref": "#/$defs/nullableMeasuredEvidence"},
        "useful_change_threshold": {"$ref": "#/$defs/nullableMeasuredEvidence"},
        "useful_change_evidence_class": {
          "type": ["string", "null"],
          "enum": [null, "geometry_derived", "literature_derived", "assumed_model_study"]
        },
        "qualification_status": {"enum": ["pending", "qualified", "blocked"]}
      }
    }
  }
}
