{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scope", "launch_status", "sources", "metrics", "qualification_rule"],
  "properties": {
    "schema_version": {"const": 1},
    "scope": {"type": "string", "minLength": 1},
    "launch_status": {"const": "blocked_pending_measurement_qualification"},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/metric"}
    },
    "qualification_rule": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "nullableNonnegative": {"type": ["number", "null"], "minimum": 0},
    "nullableEvidence": {
      "type": ["object", "null"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "selector": {"type": "string", "pattern": "^/"}
      },
      "required": ["path", "sha256", "selector"],
      "additionalProperties": false
    },
    "nullableParity": {
      "type": ["object", "null"],
      "properties": {
        "maximum_absolute_difference": {"type": "number", "minimum": 0},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "line_numbers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "integer", "minimum": 1}
        }
      },
      "required": ["maximum_absolute_difference", "path", "sha256", "line_numbers"],
      "additionalProperties": false
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "step", "extractor", "definition", "region", "units", "required_for", "missing_value_rule", "detection_limit", "known_failure_evidence", "prescribed_control_evidence", "save_reload_parity", "numerical_allowance", "repeat_allowance", "useful_change_threshold", "qualification_status"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "step": {"enum": ["mask", "bosch_etch"]},
        "extractor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "symbol", "output_key"],
          "properties": {
            "path": {"type": "string", "minLength": 1},
            "symbol": {"enum": ["pattern_metrics_2d", "etch_profile_metrics_2d"]},
            "output_key": {"type": "string", "minLength": 1}
          }
        },
        "definition": {"type": "string", "minLength": 1},
        "region": {"type": "string", "minLength": 1},
        "units": {"type": "string", "minLength": 1},
        "required_for": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["range_finding", "screening", "confirmation"]}
        },
        "missing_value_rule": {"const": "block the affected decision; never replace with zero"},
        "detection_limit": {"$ref": "#/$defs/nullableNonnegative"},
        "known_failure_evidence": {"$ref": "#/$defs/nullableEvidence"},
        "prescribed_control_evidence": {"$ref": "#/$defs/nullableEvidence"},
        "save_reload_parity": {"$ref": "#/$defs/nullableParity"},
        "numerical_allowance": {"$ref": "#/$defs/nullableNonnegative"},
        "repeat_allowance": {"$ref": "#/$defs/nullableNonnegative"},
        "useful_change_threshold": {"$ref": "#/$defs/nullableNonnegative"},
        "qualification_status": {"enum": ["pending", "qualified", "blocked"]}
      }
    }
  }
}
